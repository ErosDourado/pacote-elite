# ─────────────────────────────────────────────────────────────────
#  FIREBASE — Configuração do projeto (V9+ modular)
#  Copie este arquivo para .env.local e preencha com as chaves do seu
#  projeto no console do Firebase. NUNCA commit .env.local.
#  Prefixo VITE_ é obrigatório para que o Vite exponha no client.
# ─────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FCM_VAPID_KEY=
